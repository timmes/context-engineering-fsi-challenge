{
  "version": "v1",
  "hooks": [
    {
      "name": "lint-secrets-on-save",
      "description": "Block saving files that contain hardcoded secrets or API keys",
      "trigger": "PostFileSave",
      "matcher": "\\.py$",
      "action": {
        "type": "command",
        "command": "grep -nE '(sk_live_|sk_test_|AKIA[A-Z0-9]{16}|password\\s*=\\s*[\"\\x27][^\"\\x27]+[\"\\x27])' ${file} && exit 2 || exit 0"
      },
      "timeout": 10,
      "enabled": true
    }
  ]
}
